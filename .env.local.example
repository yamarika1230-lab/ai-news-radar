# =============================================================================
# AI News Radar - 環境変数設定
# =============================================================================
# このファイルを .env.local にコピーして値を設定してください:
#   cp .env.local.example .env.local

# -----------------------------------------------------------------------------
# Anthropic API (Azure AI 経由)
# -----------------------------------------------------------------------------
ANTHROPIC_BASE_URL=https://digital-hub.services.ai.azure.com/anthropic/
ANTHROPIC_API_KEY=xxxxx

# -----------------------------------------------------------------------------
# Vercel KV (データストレージ)
# ローカル開発時は未設定でOK（ファイルシステムフォールバックを使用）
# -----------------------------------------------------------------------------
KV_REST_API_URL=https://xxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxx

# -----------------------------------------------------------------------------
# Cron ジョブ認証
# 任意のランダム文字列を設定（例: openssl rand -hex 32 で生成）
# ローカル開発時は未設定でOK（認証スキップ）
# -----------------------------------------------------------------------------
CRON_SECRET=xxxxx

# -----------------------------------------------------------------------------
# X (Twitter) API Bearer Token
# 未設定の場合、X コレクターはスキップされます
# -----------------------------------------------------------------------------
X_BEARER_TOKEN=xxxxx

# -----------------------------------------------------------------------------
# xAI Grok API（現在未使用、X API に置き換え済み）
# -----------------------------------------------------------------------------
# XAI_API_KEY=xxxxx

# -----------------------------------------------------------------------------
# SerpApi (Google News + Google Trends)
# 未設定の場合、SerpApi コレクターはスキップされます
# -----------------------------------------------------------------------------
SERPAPI_KEY=xxxxx
